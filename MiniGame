<script>
// =============== TWEAKABLE DEFAULTS (persisted via host) ===============
const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
  "catColor": "charcoal",
  "difficulty": "chill",
  "catSize": 0.7,
  "roundLength": 50,
  "catDesign": {
    "earStyle": "pointy",
    "earColor": "base",
    "eyeShape": "round",
    "eyeColor": "#1a1210",
    "noseShape": "heart",
    "noseColor": "#c85a7a",
    "mouthShape": "smile",
    "whiskers": true,
    "stripes": true
  }
}/*EDITMODE-END*/;

// =============== GAME CONFIG ===============
const CAT_PALETTES = {
  ginger:    { base: '#e89060', shade: '#b76842', light: '#f7c89a', belly: '#fbe3cc', stripe: '#a55532' },
  charcoal:  { base: '#5a5560', shade: '#3a363f', light: '#8a8391', belly: '#c8c1cc', stripe: '#27232b' },
  calico:    { base: '#f0d9b0', shade: '#a8754a', light: '#fff2d7', belly: '#fffaf1', stripe: '#4a2a1a' },
  siamese:   { base: '#ead7bd', shade: '#7a5a44', light: '#faecd6', belly: '#fffaf1', stripe: '#5a3a2a' },
  mint:      { base: '#a8c9b2', shade: '#5a8a6a', light: '#d0e4d4', belly: '#eef5ef', stripe: '#3a5a48' }
};
const PALETTE_ORDER = ['ginger','charcoal','calico','siamese','mint'];

const DIFF = {
  chill:   { decay: 0.40, angryThresh: 18, hissCost: 10, name: 'Chill',   clawChance: 0.05, moodSwings: false, demandFreq: 0 },
  normal:  { decay: 0.70, angryThresh: 25, hissCost: 18, name: 'Normal',  clawChance: 0.12, moodSwings: false, demandFreq: 0.12 },
  hard:    { decay: 1.10, angryThresh: 32, hissCost: 28, name: 'Hard',    clawChance: 0.22, moodSwings: true,  demandFreq: 0.20 },
  brutal:  { decay: 1.70, angryThresh: 40, hissCost: 40, name: 'Brutal',  clawChance: 0.35, moodSwings: true,  demandFreq: 0.30 }
};

// =============== STATE ===============
const tweaks = { ...TWEAK_DEFAULTS };
let state = {
  playing: false,
  ended: false,
  score: 0,
  combo: 0,
  maxCombo: 0,
  sweetHits: 0,
  purr: 60,          // 0-100
  timeLeft: tweaks.roundLength,
  moodTimer: 0,      // seconds in current mood
  angry: false,
  hissCooldown: 0,
  tailTwitch: 0,     // 0-1
  lastPetAt: 0,
  spotHistory: [],   // track consecutive same-spot petting
  pettingActive: false,
  lastPet: null,     // {x,y,t}
  catBob: 0,
  blinkTimer: 0,
  blinkDur: 0,
  tailPhase: 0,
  eyeX: 0, eyeY: 0,
  earWiggle: 0,
  catX: 0, catY: 0,  // center in canvas coords
  catScale: 1,
  // anger buildup
  overPetHeat: 0,
};

let canvas, ctx;
let audio = null;
let popLayer;
let raf = null;
let lastFrame = 0;

// =============== AUDIO (WebAudio synth) ===============
function initAudio() {
  if (audio) return audio;
  try {
    const AC = window.AudioContext || window.webkitAudioContext;
    const ac = new AC();
    audio = { ac, masterGain: null };
    const g = ac.createGain(); g.gain.value = 0.35;
    g.connect(ac.destination);
    audio.masterGain = g;

    // Continuous purr loop using filtered noise + LFO
    const purrGain = ac.createGain(); purrGain.gain.value = 0;
    const noise = ac.createBufferSource();
    const buffer = ac.createBuffer(1, ac.sampleRate * 2, ac.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1) * 0.3;
    noise.buffer = buffer;
    noise.loop = true;
    const filter = ac.createBiquadFilter();
    filter.type = 'lowpass';
    filter.frequency.value = 260;
    filter.Q.value = 2;
    const lfo = ac.createOscillator();
    lfo.frequency.value = 26; // purr rate
    const lfoGain = ac.createGain(); lfoGain.gain.value = 160;
    lfo.connect(lfoGain); lfoGain.connect(filter.frequency);
    noise.connect(filter); filter.connect(purrGain); purrGain.connect(g);
    noise.start(); lfo.start();
    audio.purrGain = purrGain;
  } catch(e) { audio = null; }
  return audio;
}
function setPurrLoudness(v) {
  if (!audio) return;
  audio.purrGain.gain.setTargetAtTime(Math.max(0, Math.min(0.45, v)), audio.ac.currentTime, 0.12);
}
function beep(freq=440, dur=0.12, type='triangle', vol=0.2, slide=0) {
  if (!audio) return;
  const { ac, masterGain } = audio;
  const o = ac.createOscillator();
  const g = ac.createGain();
  o.type = type;
  o.frequency.setValueAtTime(freq, ac.currentTime);
  if (slide) o.frequency.exponentialRampToValueAtTime(freq * slide, ac.currentTime + dur);
  g.gain.setValueAtTime(0, ac.currentTime);
  g.gain.linearRampToValueAtTime(vol, ac.currentTime + 0.01);
  g.gain.exponentialRampToValueAtTime(0.0001, ac.currentTime + dur);
  o.connect(g); g.connect(masterGain);
  o.start(); o.stop(ac.currentTime + dur + 0.02);
}
function meow(happy=true) {
  if (!audio) return;
  const base = happy ? 520 : 380;
  beep(base, 0.18, 'sine', 0.18, happy ? 1.35 : 0.75);
  setTimeout(() => beep(base * (happy?1.15:0.9), 0.18, 'triangle', 0.14, happy?0.85:0.7), 80);
}
function hiss() {
  if (!audio) return;
  const { ac, masterGain } = audio;
  const noise = ac.createBufferSource();
  const b = ac.createBuffer(1, ac.sampleRate * 0.35, ac.sampleRate);
  const d = b.getChannelData(0);
  for (let i = 0; i < d.length; i++) d[i] = (Math.random()*2-1) * (1 - i/d.length);
  noise.buffer = b;
  const f = ac.createBiquadFilter(); f.type = 'highpass'; f.frequency.value = 2800;
  const g = ac.createGain(); g.gain.value = 0.3;
  noise.connect(f); f.connect(g); g.connect(masterGain);
  noise.start(); noise.stop(ac.currentTime + 0.4);
}
function chirp(up=true) {
  if (!audio) return;
  beep(up ? 880 : 440, 0.06, 'square', 0.1, up ? 1.3 : 0.8);
}

// =============== PIXEL CAT RENDERER ===============
// We draw a pixel-art cat procedurally onto a low-res offscreen canvas
// (so image-rendering: pixelated gives crisp upscale).
// The cat sits centered. Sweet spots are zones in canvas (display) coords.

const CAT_W = 96, CAT_H = 80;  // pixel-art dimensions
let catBuffer; // offscreen
function px(x, y, c) { ctx2.fillStyle = c; ctx2.fillRect(x, y, 1, 1); }
function pxRect(x, y, w, h, c) { ctx2.fillStyle = c; ctx2.fillRect(x, y, w, h); }
let ctx2;

// Draw cat at scale into main ctx. earOffset and eyeOpen/etc control expression.
function drawCat(targetCtx, cx, cy, scale, mood) {
  // mood: { eyeOpen: 0..1, mouth: 'smile'|'angry'|'neutral'|'open', earPin: 0..1, tailAngle, tailSpeed, blush }
  const pal = CAT_PALETTES[tweaks.catColor] || CAT_PALETTES.ginger;
  if (!catBuffer) {
    catBuffer = document.createElement('canvas');
    catBuffer.width = CAT_W; catBuffer.height = CAT_H;
  }
  ctx2 = catBuffer.getContext('2d');
  ctx2.clearRect(0,0,CAT_W,CAT_H);
  ctx2.imageSmoothingEnabled = false;

  // Body/head layout within 96x80 (origin top-left):
  // Body (lower torso + legs): y 50-74
  // Head circle: around (48, 32) radius ~22
  // Ears: left ~ (30,14), right ~ (66,14)
  // Tail wraps around the right

  // --- Tail (behind body) ---
  const tailAng = mood.tailAngle || 0;
  const tailBaseX = 70, tailBaseY = 58;
  // draw segmented tail
  let tx = tailBaseX, ty = tailBaseY, ang = -0.4 + tailAng;
  for (let i = 0; i < 14; i++) {
    ang += (Math.sin(state.tailPhase + i * 0.4) * 0.04) * (1 + mood.tailSpeed*2);
    const size = i < 10 ? 3 : 2;
    pxRect(Math.round(tx)-Math.floor(size/2), Math.round(ty)-Math.floor(size/2), size, size, pal.shade);
    tx += Math.cos(ang) * 2.0;
    ty += Math.sin(ang) * 2.0;
  }
  // tail tip
  pxRect(Math.round(tx)-1, Math.round(ty)-1, 2, 2, pal.stripe);

  // --- Body (sitting pose) ---
  // Lower body: rounded blob 28..68 x 50..74
  pixelFillCircle(20 + 20, 60, 22, 15, pal.base);
  // Belly lighter
  pixelFillCircle(20 + 20, 64, 14, 8, pal.belly);
  // Front legs
  pxRect(32, 66, 6, 10, pal.base);
  pxRect(58, 66, 6, 10, pal.base);
  // Paws (lighter tips)
  pxRect(32, 74, 6, 2, pal.light);
  pxRect(58, 74, 6, 2, pal.light);

  // --- Head (behind ears) ---
  pixelFillCircle(48, 32, 22, 18, pal.base);
  // cheek / chin area slightly lighter
  pixelFillCircle(48, 38, 16, 8, pal.light);

  const design = tweaks.catDesign || {};
  // --- Ears ---
  const earPin = mood.earPin || 0; // 1 = pinned back
  const earLift = (1 - earPin) * 3;
  const earWiggle = mood.earWiggle || 0;
  const earStyle = design.earStyle || 'pointy';
  const earCol = design.earColor === 'shade' ? pal.shade : (design.earColor === 'light' ? pal.light : (design.earColor === 'stripe' ? pal.stripe : pal.base));
  drawEarStyled(30, 14 - earLift + earWiggle, -1, pal, earPin, earStyle, earCol);
  drawEarStyled(66, 14 - earLift - earWiggle, 1, pal, earPin, earStyle, earCol);

  // --- Stripes on head ---
  if (design.stripes !== false) {
    pxRect(40, 18, 3, 2, pal.stripe);
    pxRect(53, 18, 3, 2, pal.stripe);
    pxRect(46, 14, 4, 2, pal.stripe);
  }

  // --- Eyes ---
  const eyeOpen = mood.eyeOpen == null ? 1 : mood.eyeOpen;
  const eyeOffX = Math.round((state.eyeX || 0) * 1);
  const eyeOffY = Math.round((state.eyeY || 0) * 1);
  const eyeShape = design.eyeShape || 'round';
  const eyeCol = design.eyeColor || '#1a1210';
  if (eyeOpen > 0.15) {
    const eh = Math.max(1, Math.round(6 * eyeOpen));
    // eye whites (not for 'dot' shape)
    if (eyeShape !== 'dot' && eyeShape !== 'line') {
      pxRect(38, 30 - Math.floor(eh/2), 6, eh, '#fffaf1');
      pxRect(52, 30 - Math.floor(eh/2), 6, eh, '#fffaf1');
    }
    if (mood.mouth === 'angry' || eyeShape === 'slit') {
      pxRect(40 + eyeOffX, 30 - Math.floor(eh/2) + 1, 1, eh - 1, eyeCol);
      pxRect(54 + eyeOffX, 30 - Math.floor(eh/2) + 1, 1, eh - 1, eyeCol);
    } else if (eyeShape === 'dot') {
      pxRect(40, 30, 2, 2, eyeCol);
      pxRect(54, 30, 2, 2, eyeCol);
    } else if (eyeShape === 'line') {
      pxRect(38, 31, 6, 1, eyeCol);
      pxRect(52, 31, 6, 1, eyeCol);
    } else if (eyeShape === 'star') {
      pxRect(39, 29, 4, 1, eyeCol); pxRect(40, 28, 2, 3, eyeCol); pxRect(39, 31, 4, 1, eyeCol);
      pxRect(53, 29, 4, 1, eyeCol); pxRect(54, 28, 2, 3, eyeCol); pxRect(53, 31, 4, 1, eyeCol);
    } else if (eyeShape === 'big') {
      pxRect(38, 28, 6, 6, '#fffaf1');
      pxRect(52, 28, 6, 6, '#fffaf1');
      pxRect(39 + eyeOffX, 29 + eyeOffY, 4, 4, eyeCol);
      pxRect(53 + eyeOffX, 29 + eyeOffY, 4, 4, eyeCol);
      pxRect(40 + eyeOffX, 30 + eyeOffY, 1, 1, '#fffaf1');
      pxRect(54 + eyeOffX, 30 + eyeOffY, 1, 1, '#fffaf1');
    } else {
      // round (default)
      pxRect(40 + eyeOffX, 30 + eyeOffY - Math.min(2, Math.floor(eh/2)), 2, Math.min(eh, 3), eyeCol);
      pxRect(54 + eyeOffX, 30 + eyeOffY - Math.min(2, Math.floor(eh/2)), 2, Math.min(eh, 3), eyeCol);
      if (eyeOpen > 0.7) {
        pxRect(41 + eyeOffX, 30 + eyeOffY - 1, 1, 1, '#fffaf1');
        pxRect(55 + eyeOffX, 30 + eyeOffY - 1, 1, 1, '#fffaf1');
      }
    }
  } else {
    pxRect(38, 31, 6, 1, eyeCol);
    pxRect(52, 31, 6, 1, eyeCol);
  }

  // --- Nose ---
  const noseShape = design.noseShape || 'heart';
  const noseCol = design.noseColor || '#c85a7a';
  if (noseShape === 'heart') {
    pxRect(46, 37, 2, 1, noseCol); pxRect(49, 37, 2, 1, noseCol);
    pxRect(46, 38, 4, 1, noseCol); pxRect(47, 39, 2, 1, noseCol);
  } else if (noseShape === 'triangle') {
    pxRect(46, 37, 4, 1, noseCol); pxRect(47, 38, 2, 1, noseCol);
  } else if (noseShape === 'round') {
    pxRect(47, 37, 2, 2, noseCol);
  } else if (noseShape === 'small') {
    pxRect(47, 38, 2, 1, noseCol);
  } else {
    pxRect(47, 37, 3, 2, noseCol);
  }

  // --- Mouth ---
  const mouthShape = design.mouthShape || 'smile';
  if (mood.mouth === 'angry') {
    pxRect(45, 41, 2, 1, '#1a1210');
    pxRect(50, 41, 2, 1, '#1a1210');
    pxRect(47, 42, 3, 1, '#1a1210');
  } else if (mood.mouth === 'open') {
    pxRect(46, 40, 5, 2, '#c85a7a');
    pxRect(47, 41, 3, 1, '#7a2a3a');
  } else if (mouthShape === 'smile') {
    pxRect(45, 40, 2, 1, '#1a1210');
    pxRect(50, 40, 2, 1, '#1a1210');
    pxRect(47, 41, 3, 1, '#1a1210');
  } else if (mouthShape === 'w') {
    // classic :3 mouth
    pxRect(45, 40, 2, 1, '#1a1210');
    pxRect(50, 40, 2, 1, '#1a1210');
    pxRect(47, 40, 1, 1, '#1a1210');
    pxRect(49, 40, 1, 1, '#1a1210');
    pxRect(48, 41, 1, 1, '#1a1210');
  } else if (mouthShape === 'flat') {
    pxRect(46, 40, 4, 1, '#1a1210');
  } else if (mouthShape === 'open') {
    pxRect(46, 40, 4, 2, '#c85a7a');
  } else if (mouthShape === 'tongue') {
    pxRect(45, 40, 2, 1, '#1a1210');
    pxRect(50, 40, 2, 1, '#1a1210');
    pxRect(47, 41, 3, 2, '#e87a8a');
  } else {
    pxRect(46, 40, 4, 1, '#1a1210');
  }

  // Whiskers
  if (design.whiskers !== false) {
    pxRect(33, 39, 4, 1, '#3d2a22');
    pxRect(59, 39, 4, 1, '#3d2a22');
    pxRect(33, 41, 4, 1, '#3d2a22');
    pxRect(59, 41, 4, 1, '#3d2a22');
  }

  // blush on happy
  if (mood.blush) {
    pxRect(36, 36, 2, 2, 'rgba(232, 122, 90, 0.5)');
    pxRect(58, 36, 2, 2, 'rgba(232, 122, 90, 0.5)');
  }

  // Draw buffer onto main canvas scaled
  const drawW = CAT_W * scale;
  const drawH = CAT_H * scale;
  targetCtx.imageSmoothingEnabled = false;
  targetCtx.drawImage(catBuffer, Math.round(cx - drawW/2), Math.round(cy - drawH/2), drawW, drawH);
}

function drawEarStyled(cx, cy, dir, pal, pin, style, col) {
  const h = Math.round(10 * (1 - pin*0.5));
  if (style === 'round') {
    for (let i = 0; i < h; i++) {
      const w = Math.max(1, Math.round((h - i) * 0.9));
      const curve = Math.round(Math.sin((i / h) * Math.PI) * 2);
      const ww = Math.max(1, w + (i < h/2 ? curve : -curve));
      pxRect(cx - Math.floor(ww/2), cy + i, ww, 1, i < 3 ? pal.shade : col);
    }
    if (pin < 0.5) {
      for (let i = 3; i < h - 2; i++) {
        const w = Math.max(1, Math.floor((h - i) * 0.4));
        pxRect(cx - Math.floor(w/2), cy + i + 1, w, 1, '#e8a7b8');
      }
    }
  } else if (style === 'folded') {
    // droopy / short
    const fh = Math.max(3, Math.round(h * 0.6));
    for (let i = 0; i < fh; i++) {
      const w = Math.max(2, fh - i + 2);
      pxRect(cx - Math.floor(w/2), cy + i + 2, w, 1, i < 2 ? pal.shade : col);
    }
  } else if (style === 'tufted') {
    // pointy with a tuft on top
    for (let i = 0; i < h; i++) {
      const w = Math.max(1, h - i);
      pxRect(cx - Math.floor(w/2), cy + i, w, 1, i < 3 ? pal.shade : col);
    }
    // tuft
    pxRect(cx, cy - 2, 1, 2, pal.stripe);
    pxRect(cx - 1, cy - 1, 1, 1, pal.stripe);
    if (pin < 0.5) {
      for (let i = 2; i < h - 2; i++) {
        const w = Math.max(1, Math.floor((h - i) * 0.5));
        pxRect(cx - Math.floor(w/2), cy + i + 1, w, 1, '#e8a7b8');
      }
    }
  } else if (style === 'big') {
    const bh = h + 3;
    for (let i = 0; i < bh; i++) {
      const w = Math.max(1, Math.round((bh - i) * 1.2));
      pxRect(cx - Math.floor(w/2), cy + i - 2, w, 1, i < 3 ? pal.shade : col);
    }
    if (pin < 0.5) {
      for (let i = 2; i < bh - 2; i++) {
        const w = Math.max(1, Math.floor((bh - i) * 0.55));
        pxRect(cx - Math.floor(w/2), cy + i - 1, w, 1, '#e8a7b8');
      }
    }
  } else {
    // pointy default
    for (let i = 0; i < h; i++) {
      const w = Math.max(1, h - i);
      pxRect(cx - Math.floor(w/2), cy + i, w, 1, i < 3 ? pal.shade : col);
    }
    if (pin < 0.5) {
      for (let i = 2; i < h - 2; i++) {
        const w = Math.max(1, Math.floor((h - i) * 0.5));
        pxRect(cx - Math.floor(w/2), cy + i + 1, w, 1, '#e8a7b8');
      }
    }
  }
}

function drawEar(cx, cy, dir, pal, pin) {
  // Triangle ear drawn as pixel rows
  // if pin is high, squash flat
  const h = Math.round(10 * (1 - pin*0.5));
  for (let i = 0; i < h; i++) {
    const w = Math.max(1, h - i);
    pxRect(cx - Math.floor(w/2), cy + i, w, 1, i < 3 ? pal.shade : pal.base);
  }
  // inner pink
  if (pin < 0.5) {
    for (let i = 2; i < h - 2; i++) {
      const w = Math.max(1, Math.floor((h - i) * 0.5));
      pxRect(cx - Math.floor(w/2), cy + i + 1, w, 1, '#e8a7b8');
    }
  }
}

function pixelFillCircle(cx, cy, rx, ry, color) {
  for (let y = -ry; y <= ry; y++) {
    for (let x = -rx; x <= rx; x++) {
      if ((x*x)/(rx*rx) + (y*y)/(ry*ry) <= 1) {
        pxRect(cx + x, cy + y, 1, 1, color);
      }
    }
  }
}

// =============== SWEET SPOTS ===============
// Defined in cat-local pixel coords (cat is drawn 96x80). We convert to canvas coords.
const SPOTS = [
  { name: 'earL',  x: 30, y: 16, r: 7,  mult: 2.0, type: 'ears' },
  { name: 'earR',  x: 66, y: 16, r: 7,  mult: 2.0, type: 'ears' },
  { name: 'chin',  x: 48, y: 40, r: 6,  mult: 1.5, type: 'chin' },
  { name: 'head',  x: 48, y: 28, r: 10, mult: 1.0, type: 'head' },
  { name: 'belly', x: 48, y: 62, r: 12, mult: -1,  type: 'belly' },
  { name: 'body',  x: 48, y: 58, r: 18, mult: 0.3, type: 'body' } // fallback
];

function getSpotAt(canvasX, canvasY) {
  // convert to cat-local pixel coords
  const dw = CAT_W * state.catScale, dh = CAT_H * state.catScale;
  const lx = (canvasX - (state.catX - dw/2)) / state.catScale;
  const ly = (canvasY - (state.catY - dh/2)) / state.catScale;
  // specific spots first (ears, chin, head, belly)
  for (const s of SPOTS) {
    if (s.name === 'body') continue;
    const dx = lx - s.x, dy = ly - s.y;
    if (dx*dx + dy*dy <= s.r*s.r) return s;
  }
  // fallback body hit only if within broad cat shape
  const bs = SPOTS.find(s => s.name === 'body');
  const dx = lx - bs.x, dy = ly - bs.y;
  if (dx*dx + dy*dy <= (bs.r*1.6)*(bs.r*1.6)) return bs;
  return null;
}

// =============== SCORING / MECHANICS ===============
function onPet(cx, cy) {
  if (!state.playing || state.ended) return;
  const now = performance.now();
  // throttle — at most one pet-hit per 90ms
  if (now - state.lastPetAt < 85) return;
  state.lastPetAt = now;

  const spot = getSpotAt(cx, cy);
  if (!spot) return;

  const diff = DIFF[tweaks.difficulty] || DIFF.normal;

  if (spot.name === 'belly') {
    // TRAP
    state.overPetHeat += 30;
    state.combo = 0;
    state.purr = Math.max(0, state.purr - 18);
    state.score = Math.max(0, state.score - 15);
    triggerShake();
    spawnPop('CLAW!', cx, cy, 'bad');
    hiss();
    return;
  }

  // RANDOM CLAW — harder difficulties can surprise you even on sweet spots.
  // Chance rises when purr is low, anger is simmering, or demand is unmet.
  let clawP = diff.clawChance;
  if (state.purr < 50) clawP *= 1.35;
  if (state.overPetHeat > 30) clawP *= 1.6;
  if (state.demandActive && state.demandSpot && state.demandSpot !== spot.type) clawP *= 1.5;
  if (state.angry) clawP *= 2.2;
  // ears are jumpier than head
  if (spot.type === 'ears') clawP *= 1.1;
  if (Math.random() < clawP) {
    state.overPetHeat += 20;
    state.combo = 0;
    state.purr = Math.max(0, state.purr - 12);
    state.score = Math.max(0, state.score - 10);
    triggerShake();
    spawnPop('CLAW!', cx, cy, 'bad');
    hiss();
    state.clawsSurvived = (state.clawsSurvived || 0);
    return;
  }

  // over-pet detection: if same spot repeatedly without variety
  state.spotHistory.push(spot.name);
  if (state.spotHistory.length > 6) state.spotHistory.shift();
  const sameSpotCount = state.spotHistory.filter(n => n === spot.name).length;
  const overpetting = sameSpotCount >= (diff.clawChance > 0.2 ? 3 : 5);

  if (overpetting) {
    state.overPetHeat += 18;
    state.combo = 0;
    state.purr = Math.max(0, state.purr - 6);
    spawnPop('boring...', cx, cy, 'neutral');
    return;
  }

  // demand bonus: if Mochi demanded a specific spot type, reward matching it
  let demandBonus = 1;
  if (state.demandActive && state.demandSpot === spot.type) {
    demandBonus = 2;
    state.demandActive = false;
    state.demandSpot = null;
    state.demandTimer = 0;
    spawnPop('DEMAND MET!', cx, cy, 'crit');
  }

  // successful pet
  const base = 10 * (spot.mult);
  const comboMult = 1 + Math.min(state.combo, 20) * 0.08;
  const crit = state.combo > 0 && state.combo % 10 === 0;
  const gain = Math.round(base * comboMult * (crit ? 1.5 : 1) * demandBonus);
  state.score += gain;
  state.combo += 1;
  state.maxCombo = Math.max(state.maxCombo, state.combo);
  state.sweetHits++;
  state.clawsSurvived = (state.clawsSurvived || 0) + 1;
  state.purr = Math.min(100, state.purr + (spot.mult * 4.5) + 1);
  state.overPetHeat = Math.max(0, state.overPetHeat - 2);

  const label = (crit ? 'PURR-FECT! +' : '+') + gain + (state.combo > 1 ? ' x' + state.combo : '');
  spawnPop(label, cx, cy, crit ? 'crit' : (spot.mult >= 1.5 ? 'good' : 'neutral'));
  chirp(spot.mult >= 1.5);
}

function triggerShake() {
  const w = document.getElementById('canvasWrap');
  w.classList.remove('shake');
  void w.offsetWidth;
  w.classList.add('shake');
}

function spawnPop(text, cx, cy, kind) {
  const rect = canvas.getBoundingClientRect();
  // cx,cy are canvas internal coords; convert to DOM pixel inside wrap
  const scaleX = rect.width / canvas.width;
  const scaleY = rect.height / canvas.height;
  const el = document.createElement('div');
  el.className = 'pop' + (kind === 'bad' ? ' bad' : kind === 'neutral' ? ' neutral' : kind === 'crit' ? ' crit' : '');
  el.style.left = (cx * scaleX) + 'px';
  el.style.top  = (cy * scaleY) + 'px';
  el.textContent = text;
  popLayer.appendChild(el);
  setTimeout(() => el.remove(), 900);
}

// =============== LOOP ===============
function loop(t) {
  if (!lastFrame) lastFrame = t;
  const dt = Math.min(0.05, (t - lastFrame) / 1000);
  lastFrame = t;
  update(dt);
  render();
  raf = requestAnimationFrame(loop);
}

function update(dt) {
  const diff = DIFF[tweaks.difficulty] || DIFF.normal;
  state.tailPhase += dt * (state.angry ? 8 : 2.5);
  state.catBob = Math.sin(performance.now()/600) * 0.5;
  state.earWiggle = Math.sin(performance.now()/220) * 0.3;

  if (!state.playing || state.ended) return;

  // Timer
  state.timeLeft -= dt;
  if (state.timeLeft <= 0) {
    state.timeLeft = 0;
    endGame();
  }

  // Purr decay (faster as time ramps = difficulty curve)
  const ramp = 1 + (1 - state.timeLeft / tweaks.roundLength) * 0.6; // up to 1.6x late game
  let decay = diff.decay * 12 * ramp * dt;
  // if angry, decay is brutal
  if (state.angry) decay *= 2.2;
  state.purr = Math.max(0, state.purr - decay);

  // Overpet heat cools
  state.overPetHeat = Math.max(0, state.overPetHeat - dt * 6);

  // DEMAND SYSTEM: Mochi demands a specific spot type for bonus points
  if (diff.demandFreq > 0) {
    if (!state.demandActive) {
      state.demandCooldown = (state.demandCooldown || 0) - dt;
      if (state.demandCooldown <= 0) {
        if (Math.random() < diff.demandFreq * dt * 2) {
          const choices = ['ears', 'chin', 'head'];
          state.demandSpot = choices[Math.floor(Math.random()*choices.length)];
          state.demandActive = true;
          state.demandTimer = 3.5;
          showMood('PET MY ' + state.demandSpot.toUpperCase() + '!', 'happy');
        }
      }
    } else {
      state.demandTimer -= dt;
      if (state.demandTimer <= 0) {
        // failed to meet demand
        state.demandActive = false;
        state.demandSpot = null;
        state.purr = Math.max(0, state.purr - 10);
        state.overPetHeat += 15;
        state.demandCooldown = 4;
        showMood('ignored!', 'angry');
      }
    }
  }

  // MOOD SWINGS: hard/brutal cat can get randomly grumpy even at high purr
  if (diff.moodSwings && !state.angry && Math.random() < 0.015 * dt * 60) {
    state.purr = Math.max(0, state.purr - 15);
    state.overPetHeat += 25;
    showMood('hmph.', 'angry');
  }

  // Anger state
  if (state.purr < diff.angryThresh || state.overPetHeat > 60) {
    if (!state.angry) {
      state.angry = true;
      state.moodTimer = 0;
      showMood('ANGRY!', 'angry');
      meow(false);
      state.score = Math.max(0, state.score - diff.hissCost);
      state.combo = 0;
      triggerShake();
    }
  } else if (state.purr > diff.angryThresh + 15) {
    if (state.angry) {
      state.angry = false;
      showMood('calming...', '');
    }
  }

  // Angry: score drains
  if (state.angry) {
    state.score = Math.max(0, state.score - dt * 8);
  }

  // Combo decay if no pet for 1.4s
  if (performance.now() - state.lastPetAt > 1400 && state.combo > 0) {
    state.combo = 0;
  }

  // blinks
  state.blinkTimer -= dt;
  if (state.blinkTimer < 0 && state.blinkDur <= 0) {
    state.blinkDur = 0.18;
    state.blinkTimer = 2.5 + Math.random()*3;
  }
  if (state.blinkDur > 0) state.blinkDur -= dt;

  // eye tracking toward last pet
  if (state.lastPet) {
    const dx = state.lastPet.x - state.catX;
    const dy = state.lastPet.y - state.catY;
    const len = Math.hypot(dx, dy) || 1;
    const targetX = Math.max(-1, Math.min(1, dx/len));
    const targetY = Math.max(-1, Math.min(1, dy/len));
    state.eyeX += (targetX - state.eyeX) * dt * 4;
    state.eyeY += (targetY - state.eyeY) * dt * 4;
  } else {
    state.eyeX *= 0.95; state.eyeY *= 0.95;
  }

  // audio purr loudness follows meter
  setPurrLoudness((state.purr/100) * 0.4 * (state.angry ? 0 : 1));

  // HUD
  const scoreEl = document.getElementById('scoreVal');
  scoreEl.textContent = Math.floor(state.score);
  const timeEl = document.getElementById('timeVal');
  timeEl.textContent = Math.ceil(state.timeLeft);
  timeEl.classList.toggle('low', state.timeLeft < 10);

  const fill = document.getElementById('meterFill');
  fill.style.width = state.purr + '%';
  fill.classList.toggle('warn', state.purr < 40 && state.purr >= diff.angryThresh);
  fill.classList.toggle('danger', state.purr < diff.angryThresh);

  const moodLbl = document.getElementById('moodLabel');
  const moodDot = document.getElementById('moodDot');
  moodDot.className = 'mood-dot';
  if (state.angry) { moodLbl.textContent = 'ANGRY'; moodDot.classList.add('angry'); }
  else if (state.purr < 50) { moodLbl.textContent = 'ANTSY'; moodDot.classList.add('neutral'); }
  else if (state.purr > 80) { moodLbl.textContent = 'BLISSFUL'; }
  else { moodLbl.textContent = 'CONTENT'; }
}

function showMood(text, kind) {
  const el = document.getElementById('moodBanner');
  el.textContent = text;
  el.className = 'mood-banner show ' + (kind || '');
  clearTimeout(showMood._t);
  showMood._t = setTimeout(() => el.classList.remove('show'), 1400);
}

function render() {
  if (!ctx) return;
  ctx.imageSmoothingEnabled = false;
  // background
  const grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
  grad.addColorStop(0, '#ffe9cf');
  grad.addColorStop(1, '#f8d3b0');
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  // Floor rug (pixel-ish)
  ctx.fillStyle = '#e8c2a0';
  ctx.fillRect(0, canvas.height - 80, canvas.width, 80);
  // rug stripes
  ctx.fillStyle = '#d9a87a';
  for (let i = 0; i < canvas.width; i += 40) {
    ctx.fillRect(i, canvas.height - 80, 20, 80);
  }

  // Decorative hearts floating when happy
  if (state.purr > 70 && state.playing) {
    drawHearts();
  }

  // Cat position
  state.catX = canvas.width / 2;
  state.catY = canvas.height / 2 + 30 + state.catBob * 4;
  state.catScale = 4 * tweaks.catSize;

  // Determine mood visual
  const mood = {
    eyeOpen: state.blinkDur > 0 ? 0 : (state.angry ? 0.6 : 1),
    mouth: state.angry ? 'angry' : (state.purr > 70 ? 'smile' : 'neutral'),
    earPin: state.angry ? 0.85 : (state.overPetHeat / 100),
    tailAngle: state.angry ? Math.sin(state.tailPhase)*0.6 : Math.sin(state.tailPhase)*0.15,
    tailSpeed: state.angry ? 1 : (state.overPetHeat > 30 ? 0.6 : 0.15),
    earWiggle: state.earWiggle,
    blush: state.purr > 80 && !state.angry
  };

  drawCat(ctx, state.catX, state.catY, state.catScale, mood);

  // Z's when very content (sleepy) — little bonus flair
  if (state.purr > 90 && !state.angry) {
    ctx.fillStyle = '#6b4a3b';
    ctx.font = 'bold 16px "Press Start 2P", monospace';
    ctx.fillText('z', state.catX + 80, state.catY - 80 + Math.sin(performance.now()/400)*3);
  }

  // Sweet-spot hint rings (subtle when near cursor)
  if (state.playing && hoverPos) {
    const spot = getSpotAt(hoverPos.x, hoverPos.y);
    if (spot && spot.name !== 'body') {
      ctx.save();
      ctx.globalAlpha = 0.5;
      ctx.strokeStyle = spot.name === 'belly' ? '#c85a5a' :
                        spot.type === 'ears'  ? '#c27bd0' :
                        spot.type === 'chin'  ? '#6aa9db' : '#e0a040';
      ctx.lineWidth = 3;
      const dw = CAT_W * state.catScale, dh = CAT_H * state.catScale;
      const scx = (state.catX - dw/2) + spot.x * state.catScale;
      const scy = (state.catY - dh/2) + spot.y * state.catScale;
      ctx.beginPath();
      ctx.arc(scx, scy, spot.r * state.catScale + 4, 0, Math.PI*2);
      ctx.stroke();
      ctx.restore();
    }
  }

  // "Angry" red tint over canvas
  if (state.angry) {
    ctx.fillStyle = 'rgba(200, 90, 90, 0.15)';
    ctx.fillRect(0,0,canvas.width, canvas.height);
  }
}

// floating hearts
const hearts = [];
function drawHearts() {
  if (Math.random() < 0.04) {
    hearts.push({ x: state.catX + (Math.random()*80-40), y: state.catY - 40, life: 0, vy: -0.4 - Math.random()*0.5 });
  }
  ctx.fillStyle = '#e07a4f';
  for (let i = hearts.length - 1; i >= 0; i--) {
    const h = hearts[i];
    h.y += h.vy;
    h.life += 1;
    if (h.life > 90) { hearts.splice(i,1); continue; }
    // pixel heart 5x4
    const s = 3;
    const hx = Math.round(h.x), hy = Math.round(h.y);
    const a = Math.max(0, 1 - h.life/90);
    ctx.globalAlpha = a;
    ctx.fillRect(hx - s*2, hy, s, s);
    ctx.fillRect(hx + s, hy, s, s);
    ctx.fillRect(hx - s*2, hy + s, s*4, s);
    ctx.fillRect(hx - s, hy + s*2, s*2, s);
    ctx.globalAlpha = 1;
  }
}

// =============== INPUT ===============
let hoverPos = null;
function canvasCoords(evt) {
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.width / rect.width;
  const scaleY = canvas.height / rect.height;
  const cx = (evt.clientX - rect.left) * scaleX;
  const cy = (evt.clientY - rect.top) * scaleY;
  return { x: cx, y: cy };
}

function attachInput() {
  canvas.addEventListener('pointerdown', (e) => {
    initAudio();
    if (audio && audio.ac.state === 'suspended') audio.ac.resume();
    state.pettingActive = true;
    canvas.setPointerCapture(e.pointerId);
    canvas.classList.add('petting');
    const p = canvasCoords(e);
    state.lastPet = { x: p.x, y: p.y, t: performance.now() };
    onPet(p.x, p.y);
  });
  canvas.addEventListener('pointermove', (e) => {
    const p = canvasCoords(e);
    hoverPos = p;
    if (state.pettingActive) {
      // Require minimum movement to register a new pet (encourages stroking)
      const dx = p.x - state.lastPet.x, dy = p.y - state.lastPet.y;
      const dist = Math.hypot(dx, dy);
      if (dist > 12) {
        state.lastPet = { x: p.x, y: p.y, t: performance.now() };
        onPet(p.x, p.y);
      }
    }
  });
  const stop = (e) => {
    state.pettingActive = false;
    canvas.classList.remove('petting');
  };
  canvas.addEventListener('pointerup', stop);
  canvas.addEventListener('pointercancel', stop);
  canvas.addEventListener('pointerleave', () => { hoverPos = null; });
}

// =============== GAME FLOW ===============
function startGame() {
  state = {
    ...state,
    playing: true,
    ended: false,
    score: 0, combo: 0, maxCombo: 0, sweetHits: 0, clawsSurvived: 0,
    purr: 65,
    timeLeft: tweaks.roundLength,
    angry: false, overPetHeat: 0,
    spotHistory: [],
    lastPet: null, pettingActive: false,
    lastPetAt: 0,
    eyeX: 0, eyeY: 0,
    demandActive: false, demandSpot: null, demandTimer: 0, demandCooldown: 2,
  };
  hearts.length = 0;
  document.getElementById('startOverlay').classList.add('hidden');
  document.getElementById('endOverlay').classList.add('hidden');
  showMood('Hi!', 'happy');
  meow(true);
}

function endGame() {
  state.playing = false;
  state.ended = true;
  setPurrLoudness(0);
  const overlay = document.getElementById('endOverlay');
  overlay.classList.remove('hidden');
  const score = Math.floor(state.score);
  document.getElementById('endScore').textContent = score.toString();
  const diff = DIFF[tweaks.difficulty];
  let msg = '', title = '';
  if (score >= 1500)      { title = 'PURRFECT!'; msg = 'Mochi is in love. Best pets of the week.'; }
  else if (score >= 900)  { title = 'Nice pets!'; msg = 'Mochi purred happily through it all.'; }
  else if (score >= 400)  { title = "Not bad"; msg = 'A solid session. Mochi\'s tail is still.'; }
  else                    { title = 'Oof'; msg = 'Mochi expected better. Try the sweet spots.'; }
  document.getElementById('endTitle').textContent = title;
  document.getElementById('endMsg').textContent = msg;
  document.getElementById('tagMax').textContent = 'Max combo: ' + state.maxCombo;
  document.getElementById('tagSweet').textContent = 'Sweet hits: ' + state.sweetHits;
  updateLastRun(score);
  updatePersonalRecord(score);
}

function updateLastRun(score) {
  const el = document.getElementById('lastRun');
  const diff = DIFF[tweaks.difficulty];
  el.innerHTML = `
    <div><b>Score:</b> ${score}</div>
    <div><b>Max combo:</b> ${state.maxCombo}</div>
    <div><b>Sweet hits:</b> ${state.sweetHits}</div>
    <div><b>Claws survived:</b> ${state.clawsSurvived || 0}</div>
    <div><b>Difficulty:</b> ${diff.name}</div>
    <div><b>Round:</b> ${tweaks.roundLength}s</div>
  `;
}

// =============== PERSONAL RECORD ===============
const PR_KEY = 'mochi-personal-record-v2';
function loadPR() {
  try { return JSON.parse(localStorage.getItem(PR_KEY) || 'null'); } catch(e) { return null; }
}
function savePR(pr) { localStorage.setItem(PR_KEY, JSON.stringify(pr)); }
function renderPR(highlight) {
  const pr = loadPR();
  const bigEl = document.getElementById('prScore');
  const subEl = document.getElementById('prSub');
  const metaEl = document.getElementById('prMeta');
  if (!bigEl || !subEl || !metaEl) return;
  if (!pr) {
    bigEl.textContent = '—';
    subEl.textContent = 'No runs yet — get out there and pet.';
    metaEl.innerHTML = '';
    return;
  }
  bigEl.textContent = pr.score;
  subEl.innerHTML = highlight ? '<span class="pr-new">NEW RECORD!</span>' : 'Your best yet.';
  const d = new Date(pr.ts);
  metaEl.innerHTML = `
    <div><span>Max combo</span><b>${pr.maxCombo}</b></div>
    <div><span>Sweet hits</span><b>${pr.sweetHits}</b></div>
    <div><span>Difficulty</span><b>${pr.difficulty}</b></div>
    <div><span>Round</span><b>${pr.length}s</b></div>
    <div><span>Set</span><b>${d.toLocaleDateString()}</b></div>
  `;
}
function updatePersonalRecord(score) {
  const pr = loadPR();
  const diff = DIFF[tweaks.difficulty];
  const entry = {
    score,
    maxCombo: state.maxCombo,
    sweetHits: state.sweetHits,
    difficulty: diff.name,
    length: tweaks.roundLength,
    ts: Date.now()
  };
  const isNew = !pr || score > pr.score;
  if (isNew && score > 0) savePR(entry);
  renderPR(isNew && score > 0);
  const hint = document.getElementById('saveHint');
  if (hint) hint.textContent = isNew && score > 0 ? '🏅 New personal record!' : (pr ? `Record to beat: ${pr.score}` : '');
}

// =============== TWEAKS (host protocol) ===============
function applyTweaks() {
  // size label
  document.getElementById('sizeLabel').textContent = tweaks.catSize.toFixed(2) + 'x';
  document.getElementById('lenLabel').textContent = tweaks.roundLength + 's';
  document.getElementById('sizeRange').value = tweaks.catSize;
  document.getElementById('lenRange').value = tweaks.roundLength;
  document.getElementById('diffSelect').value = tweaks.difficulty;
  // swatches
  const sw = document.getElementById('colorSwatches');
  sw.innerHTML = '';
  PALETTE_ORDER.forEach(k => {
    const d = document.createElement('div');
    d.className = 'swatch' + (tweaks.catColor === k ? ' selected' : '');
    d.style.background = CAT_PALETTES[k].base;
    d.title = k;
    d.onclick = () => { tweaks.catColor = k; applyTweaks(); persist({ catColor: k }); };
    sw.appendChild(d);
  });
}
function persist(edits) {
  try {
    window.parent.postMessage({ type: '__edit_mode_set_keys', edits }, '*');
  } catch(e) {}
}

function setupTweakListeners() {
  document.getElementById('diffSelect').onchange = (e) => {
    tweaks.difficulty = e.target.value;
    persist({ difficulty: tweaks.difficulty });
  };
  document.getElementById('sizeRange').oninput = (e) => {
    tweaks.catSize = parseFloat(e.target.value);
    document.getElementById('sizeLabel').textContent = tweaks.catSize.toFixed(2) + 'x';
    persist({ catSize: tweaks.catSize });
  };
  document.getElementById('lenRange').oninput = (e) => {
    tweaks.roundLength = parseInt(e.target.value);
    document.getElementById('lenLabel').textContent = tweaks.roundLength + 's';
    persist({ roundLength: tweaks.roundLength });
  };
  document.getElementById('tweaksClose').onclick = () => {
    document.getElementById('tweaksPanel').classList.remove('on');
  };
}

window.addEventListener('message', (e) => {
  const d = e.data;
  if (!d || !d.type) return;
  if (d.type === '__activate_edit_mode') {
    document.getElementById('tweaksPanel').classList.add('on');
  } else if (d.type === '__deactivate_edit_mode') {
    document.getElementById('tweaksPanel').classList.remove('on');
  }
});

// =============== INIT ===============
function init() {
  canvas = document.getElementById('game');
  ctx = canvas.getContext('2d');
  // pop layer = canvas-wrap
  popLayer = document.getElementById('canvasWrap');

  applyTweaks();
  setupTweakListeners();
  renderPR(false);
  attachInput();

  document.getElementById('startBtn').onclick = () => startGame();
  document.getElementById('againBtn').onclick = () => startGame();
  const prReset = document.getElementById('prResetBtn');
  if (prReset) prReset.onclick = () => {
    if (confirm('Reset your personal record?')) {
      localStorage.removeItem(PR_KEY);
      renderPR(false);
    }
  };
  document.getElementById('howBtn').onclick = () => {
    document.getElementById('howOverlay').classList.remove('hidden');
  };
  const sb = document.getElementById('settingsBtn');
  if (sb) sb.onclick = () => document.getElementById('tweaksPanel').classList.add('on');
  document.getElementById('howCloseBtn').onclick = () => {
    document.getElementById('howOverlay').classList.add('hidden');
  };

  raf = requestAnimationFrame(loop);

  // Announce tweaks available
  try { window.parent.postMessage({ type: '__edit_mode_available' }, '*'); } catch(e) {}
}

document.addEventListener('DOMContentLoaded', init);

// =============== CAT DESIGNER ===============
const DESIGNER_OPTIONS = {
  earStyle:   [['pointy','Pointy'],['round','Round'],['folded','Folded'],['tufted','Tufted'],['big','Big']],
  earColor:   [['base','Body'],['shade','Dark'],['light','Light'],['stripe','Accent']],
  eyeShape:   [['round','Round'],['big','Big'],['dot','Dot'],['line','Closed'],['slit','Slit'],['star','Star']],
  noseShape:  [['heart','Heart'],['triangle','Triangle'],['round','Round'],['small','Small']],
  mouthShape: [['smile','Smile :)'],['w','Kitty :3'],['flat','Flat'],['open','Open'],['tongue','Tongue']],
};
const EYE_COLORS  = ['#1a1210','#3a6a4a','#4a6ab8','#b06820','#8a4ab8','#d8a040','#c85a5a','#2a8a8a'];
const NOSE_COLORS = ['#c85a7a','#3d2a22','#e89060','#8a4a5a','#f0a0b8','#a83d3d'];

function getDesign() {
  return Object.assign({
    earStyle: 'pointy', earColor: 'base',
    eyeShape: 'round', eyeColor: '#1a1210',
    noseShape: 'heart', noseColor: '#c85a7a',
    mouthShape: 'smile', whiskers: true, stripes: true
  }, tweaks.catDesign || {});
}

function setDesign(patch) {
  tweaks.catDesign = Object.assign(getDesign(), patch);
  renderDesignerPreview();
  persist({ catDesign: tweaks.catDesign });
}

function buildDesignerControls() {
  const root = document.getElementById('designerControls');
  root.innerHTML = '';
  const d = getDesign();

  function group(title, html) {
    const g = document.createElement('div');
    g.className = 'ctrl-group';
    g.innerHTML = `<label>${title}</label>${html}`;
    root.appendChild(g);
    return g;
  }
  function optRow(key, options, current) {
    return `<div class="opt-row" data-key="${key}">` +
      options.map(([v, lbl]) => `<button class="opt ${v===current?'active':''}" data-val="${v}">${lbl}</button>`).join('') +
    `</div>`;
  }
  function colorRow(key, colors, current) {
    return `<div class="color-picker-row" data-key="${key}">` +
      colors.map(c => `<div class="color-pick ${c===current?'active':''}" data-val="${c}" style="background:${c}"></div>`).join('') +
    `</div>`;
  }

  group('EARS — SHAPE',   optRow('earStyle', DESIGNER_OPTIONS.earStyle, d.earStyle));
  group('EARS — TINT',    optRow('earColor', DESIGNER_OPTIONS.earColor, d.earColor));
  group('EYES — SHAPE',   optRow('eyeShape', DESIGNER_OPTIONS.eyeShape, d.eyeShape));
  group('EYES — COLOR',   colorRow('eyeColor', EYE_COLORS, d.eyeColor));
  group('NOSE — SHAPE',   optRow('noseShape', DESIGNER_OPTIONS.noseShape, d.noseShape));
  group('NOSE — COLOR',   colorRow('noseColor', NOSE_COLORS, d.noseColor));
  group('MOUTH',          optRow('mouthShape', DESIGNER_OPTIONS.mouthShape, d.mouthShape));
  group('EXTRAS',
    `<div class="toggle-row">
      <button class="opt ${d.whiskers?'active':''}" data-toggle="whiskers">Whiskers</button>
      <button class="opt ${d.stripes?'active':''}" data-toggle="stripes">Stripes</button>
    </div>`);

  // delegate clicks
  root.onclick = (e) => {
    const opt = e.target.closest('.opt[data-val], .color-pick[data-val]');
    if (opt) {
      const row = opt.closest('[data-key]');
      const key = row.dataset.key;
      const val = opt.dataset.val;
      setDesign({ [key]: val });
      row.querySelectorAll('.active').forEach(n => n.classList.remove('active'));
      opt.classList.add('active');
      return;
    }
    const tgl = e.target.closest('.opt[data-toggle]');
    if (tgl) {
      const key = tgl.dataset.toggle;
      const cur = getDesign()[key];
      setDesign({ [key]: !cur });
      tgl.classList.toggle('active', !cur);
    }
  };
}

function renderDesignerPreview() {
  const pc = document.getElementById('previewCanvas');
  if (!pc) return;
  const pctx = pc.getContext('2d');
  pctx.imageSmoothingEnabled = false;
  const g = pctx.createLinearGradient(0, 0, 0, pc.height);
  g.addColorStop(0, '#ffe9cf'); g.addColorStop(1, '#f8d3b0');
  pctx.fillStyle = g; pctx.fillRect(0,0,pc.width,pc.height);
  pctx.fillStyle = '#e8c2a0';
  pctx.fillRect(0, pc.height-60, pc.width, 60);
  pctx.fillStyle = '#d9a87a';
  for (let i = 0; i < pc.width; i += 30) pctx.fillRect(i, pc.height-60, 15, 60);
  const mood = { eyeOpen: 1, mouth: 'neutral', earPin: 0, tailAngle: 0, tailSpeed: 0.1, earWiggle: 0, blush: true };
  drawCat(pctx, pc.width/2, pc.height/2 + 20, 3.2, mood);
}

function openDesigner() {
  buildDesignerControls();
  renderDesignerPreview();
  document.getElementById('designerModal').classList.add('on');
}
function closeDesigner() {
  document.getElementById('designerModal').classList.remove('on');
}

// wire buttons after DOM ready
window.addEventListener('load', () => {
  const db = document.getElementById('designBtn');
  if (db) db.onclick = openDesigner;
  const dc = document.getElementById('designerClose');
  if (dc) dc.onclick = closeDesigner;
  const ds = document.getElementById('designerSave');
  if (ds) ds.onclick = closeDesigner;
  const dr = document.getElementById('designerReset');
  if (dr) dr.onclick = () => {
    setDesign({
      earStyle: 'pointy', earColor: 'base',
      eyeShape: 'round', eyeColor: '#1a1210',
      noseShape: 'heart', noseColor: '#c85a7a',
      mouthShape: 'smile', whiskers: true, stripes: true
    });
    buildDesignerControls();
  };
  // redraw preview when color changes externally
  const obs = new MutationObserver(() => {});
  // background tail animation in preview
  setInterval(() => {
    if (document.getElementById('designerModal').classList.contains('on')) {
      state.tailPhase += 0.15;
      renderDesignerPreview();
    }
  }, 120);
});
